let layout_marker = config.root.join(".oxidian").join(".layout_applied");
if !layout_marker.exists() {
    cx.defer(move |cx| {
        // El defer garantiza que los panels ya están registrados
        // Necesitamos acceso al workspace — usar el WeakEntity que ya tenemos
