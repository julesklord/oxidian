use feature_flags::{FeatureFlagAppExt, OxidianBacklinksPanel, OxidianDailyNotesPanel, OxidianFrontmatterPanel};

pub fn init(fs: Arc<dyn Fs>, features: OxidianFeatures, cx: &mut App) {
    oxidian_vault::init(fs.clone(), cx);
    log::info!("Oxidian: vault index initialized");

    // El flag de GPUI tiene prioridad sobre el config si está definido;
    // si no está definido, cae al valor de OxidianFeatures.
    let backlinks = cx.has_flag::<OxidianBacklinksPanel>()
        .unwrap_or(features.backlinks_panel);
    let daily = cx.has_flag::<OxidianDailyNotesPanel>()
        .unwrap_or(features.daily_notes_panel);
    let frontmatter = cx.has_flag::<OxidianFrontmatterPanel>()
        .unwrap_or(features.frontmatter_panel);

    if backlinks {
        oxidian_backlinks::init(cx);
        log::info!("Oxidian: backlinks panel initialized");
    }
    if daily {
        oxidian_daily::init(cx);
        log::info!("Oxidian: daily notes panel initialized");
    }
    if frontmatter {
        oxidian_frontmatter::init(cx);
        log::info!("Oxidian: frontmatter/tags panel initialized");
    }
}
```

